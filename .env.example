# Example environment variables

# The base URL of your application — also used as the better-auth baseURL.
# Leave empty for local development (falls back to http://localhost:3000 or
# the Vercel deployment URL); set to https://yourdomain.com in production.
NEXT_PUBLIC_APP_URL=

# Enable Vercel Analytics (1 for true, 0 for false)
NEXT_PUBLIC_ANALYTICS_VERCEL=0

# Enable Vercel debug output (1 for true, 0 for false)
NEXT_PUBLIC_VERCEL_DEBUG=0

# Enable developer debug mode (1 for true, 0 for false)
NEXT_PUBLIC_DEVELOPER_DEBUG=0

# Google Analytics ID
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# Matches the local Postgres from compose.yaml (docker compose up -d).
# Point this at your own database in production.
# If port 5432 is taken on your machine, set POSTGRES_PORT (e.g. 5433) and
# update the port here to match.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/boot_nextjs"
# POSTGRES_PORT=5432

# Better Auth configuration
# REQUIRED in production — generate a real secret, do not ship this placeholder:
#   openssl rand -base64 32
# 认证密钥，生产环境必须替换为真正的随机字符串（openssl rand -base64 32）
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="your-secret-key-should-be-at-least-32-chars-long"

# GitHub OAuth credentials
# 请在 GitHub 开发者设置中创建 OAuth 应用并获取这些值
# https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Google OAuth credentials
# 请在 Google Cloud Console 创建 OAuth 客户端并获取这些值
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Payment with Stripe
# https://docs.stripe.com/keys
#
# 1. Get your secret key: https://dashboard.stripe.com/apikeys
# 2. Create the webhook endpoint <your-domain>/api/auth/stripe/webhook and
#    subscribe to checkout.session.* and customer.subscription.* events.
#    For local development run:
#      stripe listen --forward-to localhost:3000/api/auth/stripe/webhook
# 3. Enable the payment methods you want (cards, Alipay, WeChat Pay, Link, ...)
#    in https://dashboard.stripe.com/settings/payment_methods — Checkout picks
#    them up automatically, no code changes needed.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Subscription plan price IDs (Dashboard -> Product catalog).
# Plans without a price ID are hidden from checkout. The *_ANNUAL variants are
# optional and enable monthly/yearly switching via the Billing Portal.
STRIPE_PRICE_SUPPORTER=
STRIPE_PRICE_SUPPORTER_ANNUAL=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_PROFESSIONAL_ANNUAL=
STRIPE_PRICE_PARTNER=
STRIPE_PRICE_PARTNER_ANNUAL=

# One-time purchase price IDs (see src/lib/stripe/products.ts).
STRIPE_PRICE_LIFETIME=
